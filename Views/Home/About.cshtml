@{
	ViewData["Title"] = "About Kyle";
}

<!DOCTYPE html>
<html>
<head>
	<meta charset="utf-8" />
	<title>Portfolio</title>
	<link rel="stylesheet" href="~/Content/site.css" />
</head>
<body>
	<h1 class="title" style="text-align: center;">@ViewData["Title"]</h1>
	<section class="section">
		<h2>About Me</h2>
		<div class="container">

		</div>
	</section>
	<section class="section">
		<h2>Education</h2>
		<div class="grid">
			<div class="card">
				<h4>Western Oregon University</h4>
				<p class="main-text">Bachelors Degree in Computer Science (2022 - 2025) <br/>
					Graduated Magna Cum Laude (3.69 GPA)</p>
			</div>
			<div class="card">
				<h4>Santa Fe High School</h4>
				<p class="main-text">High School Diploma (2014 - 2017) - Graduated</p>
			</div>
		</div>
	</section>
	<section class="awards">
		<h2>Awards</h2>
		<div class="card">
			<h4>Honor Roll</h4>
			<div class="skills">
				<span>Spring 2022</span>
				<span>Fall 2022</span>
				<span>Spring 2023</span>
				<span>Fall 2023</span>
				<span>Winter 2023</span>
				<span>Spring 2024</span>
				<span>Fall 2024</span>
				<span>Winter 2025</span>
			</div>
		</div>
	</section>
</body>
</html>